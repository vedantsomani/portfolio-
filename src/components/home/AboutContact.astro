---
import { Download, ExternalLink, Mail } from "lucide-react";

// TODO: replace the GitHub/LinkedIn root URLs with real profile links,
// and replace the resume route with a PDF when the final document is ready.
const links = [
  { label: "Email", href: "mailto:vedantsomani12@gmail.com", icon: Mail },
  { label: "GitHub", href: "https://github.com/", icon: ExternalLink },
  { label: "LinkedIn", href: "https://www.linkedin.com/", icon: ExternalLink },
  { label: "Resume PDF", href: "/resume", icon: Download },
];
---

<section id="contact" class="contact-band">
  <div class="container contact-shell" data-reveal>
    <div class="contact-copy">
      <p class="micro-label" style="color: #60a5fa">About</p>
      <h2>About / Contact</h2>
      <p>
        I am Vedant Somani, an engineering student focused on robotics, embedded systems, and
        secure communication.
      </p>
      <p>
        My work sits at the intersection of hardware, software, and failure: Pixhawk drone systems,
        ESP32 telemetry, Rust security protocols, and 3D printed mechanical prototypes.
      </p>
      <p>
        This portfolio is a public engineering log: what I built, what broke, what I verified, and
        what still needs work.
      </p>
    </div>
    <div class="contact-links">
      {links.map((link) => (
        <a class="button" href={link.href}>
          <link.icon size={17} aria-hidden="true" />
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-band {
    border-top: 1px solid var(--hairline);
    padding-block: clamp(3.5rem, 7vw, 6.5rem);
  }

  .contact-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.6fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .contact-copy {
    display: grid;
    gap: 1rem;
  }

  .contact-copy h2 {
    font-size: clamp(1.8rem, 3.6vw, 2.7rem);
    line-height: 1.02;
  }

  .contact-copy p:not(.micro-label) {
    max-width: 62ch;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .contact-links {
    display: grid;
    gap: 0.7rem;
  }

  .contact-links .button {
    justify-content: flex-start;
    --accent: #60a5fa;
  }

  @media (max-width: 760px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
