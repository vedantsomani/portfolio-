---
import EvidenceGrid from "@components/proof/EvidenceGrid.astro";
import MainLayout from "@layouts/MainLayout.astro";
import { proofArtifacts } from "@lib/proof";

const totals = [
  { label: "Artifacts", value: String(proofArtifacts.length) },
  { label: "Needs real media", value: String(proofArtifacts.filter((item) => item.status === "needs-real-asset").length) },
  { label: "Cached/live slots", value: String(proofArtifacts.filter((item) => item.status === "cached").length) },
];
---

<MainLayout
  accent="#60a5fa"
  meta={{
    title: "Proof Archive",
    description: "Evidence archive for VEDANT LAB missions, including logs, screenshots, diagrams, code, photos, CAD, and API contracts.",
    image: "/visuals/proof-archive.svg",
  }}
>
  <section class="archive-hero">
    <div class="container-wide archive-grid">
      <div>
        <p class="micro-label" style="color: #60a5fa">Proof Archive</p>
        <h1>Evidence Is The Interface</h1>
        <p>Every strong claim should resolve to a log, screenshot, diagram, code trace, photo, CAD export, or incident note.</p>
      </div>
      <div class="archive-stats">
        {totals.map((item) => (
          <div class="technical-panel">
            <span>{item.label}</span>
            <strong class="mono-value">{item.value}</strong>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band">
    <div class="container-wide archive-body">
      <EvidenceGrid artifacts={proofArtifacts} />
    </div>
  </section>
</MainLayout>

<style>
  .archive-hero {
    padding-block: clamp(6rem, 10vw, 9rem) clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--hairline);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 2rem;
    align-items: end;
  }

  h1 {
    max-width: 12ch;
    margin-top: 0.9rem;
    font-size: clamp(3rem, 8vw, 5.8rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.9;
  }

  .archive-grid p:not(.micro-label) {
    max-width: 62ch;
    margin-top: 1.1rem;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    line-height: 1.75;
  }

  .archive-stats {
    display: grid;
    gap: 0.8rem;
  }

  .archive-stats .technical-panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
  }

  .archive-stats span {
    color: var(--color-text-muted);
  }

  .archive-stats strong {
    color: var(--color-text-strong);
    font-size: 1.35rem;
  }

  @media (max-width: 820px) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
